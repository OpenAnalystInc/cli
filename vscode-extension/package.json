{
  "name": "openanalyst-cli-companion",
  "displayName": "OpenAnalyst CLI Companion",
  "description": "Enable OpenAnalyst CLI with direct access to your IDE workspace.",
  "version": "1.0.0",
  "publisher": "openanalyst",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnitChaudhry/openanalyst-cli.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "license": "MIT",
  "categories": [
    "AI"
  ],
  "keywords": [
    "openanalyst",
    "openanalyst-cli",
    "cli",
    "ai agent",
    "ide integration",
    "ide companion"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "OpenAnalyst CLI",
      "properties": {
        "openanalyst-cli.debug.logging.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable detailed logging for debugging the OpenAnalyst CLI Companion."
        }
      }
    },
    "commands": [
      {
        "command": "openanalyst.diff.accept",
        "title": "OpenAnalyst CLI: Accept Diff",
        "icon": "$(check)"
      },
      {
        "command": "openanalyst.diff.cancel",
        "title": "OpenAnalyst CLI: Close Diff Editor",
        "icon": "$(close)"
      }
    ]
  },
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.99.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
