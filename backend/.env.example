# ── OpenAnalyst Knowledge Base API Configuration ──

# Server
HOST=0.0.0.0
PORT=8420

# Auth — comma-separated API keys (leave empty for dev mode)
OPENANALYST_API_KEYS=oa_dev_key_123

# Backend selector: "sqlite" or "neo4j"
KB_BACKEND=sqlite

# ── SQLite backend (existing pipeline) ──
SQLITE_KB_DB=/path/to/catalog/transcript_knowledge_base.db
SQLITE_CATALOG_DB=/path/to/catalog/transcription_catalog.db
SQLITE_QDRANT_PATH=/path/to/catalog/transcript_qdrant
SQLITE_TRANSCRIPTIONS_ROOT=/path/to/transcriptions
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Neo4j backend (AWS) ──
NEO4J_URI=bolt://your-ec2-instance:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password
NEO4J_DATABASE=neo4j

# ── LLM synthesis ──
SYNTHESIS_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Override default model per provider (optional)
# SYNTHESIS_MODEL=gemini-2.0-flash
